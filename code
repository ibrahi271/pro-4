```bash
# Step 1: Update Ubuntu packages
sudo apt update

# Step 2: Install Docker in Ubuntu
sudo apt install docker.io -y

# Step 3: Start Docker service
sudo systemctl start docker

# Step 4: Enable Docker service at boot
sudo systemctl enable docker

# Step 5: Check Docker installation version
docker --version

# Step 6: Create project folder
mkdir myapp

# Step 7: Move into project folder
cd myapp

# Step 8: Create Python application file
nano app.py
```

```python
# Simple Python application
print("Hello from Docker Container")
```

```bash
# Step 9: Save file using CTRL+X, Y, ENTER

# Step 10: Create Dockerfile
nano Dockerfile
```

```Dockerfile
# Base operating system image
FROM ubuntu:latest

# Install Python inside container
RUN apt update && apt install -y python3

# Set working directory inside container
WORKDIR /app

# Copy project files into container
COPY . /app

# Run application automatically
CMD ["python3", "app.py"]
```

```bash
# Step 11: Save Dockerfile using CTRL+X, Y, ENTER

# Step 12: Build Docker image from Dockerfile
sudo docker build -t myapp-image .

# Step 13: View created Docker images
sudo docker images

# Step 14: Run container using Docker image
sudo docker run --name mycontainer myapp-image

# Step 15: Check running containers
sudo docker ps

# Step 16: Check all containers
sudo docker ps -a

# Step 17: Stop running container
sudo docker stop mycontainer

# Step 18: Start stopped container
sudo docker start mycontainer

# Step 19: View container logs/output
sudo docker logs mycontainer

# Step 20: Remove container
sudo docker rm mycontainer

# Step 21: Remove Docker image
sudo docker rmi myapp-image
```

## GitHub Repository Method

```bash
# Step 1: Clone repository from GitHub
git clone https://github.com/username/repository.git

# Step 2: Move into repository folder
cd repository

# Step 3: Build Docker image from repository files
sudo docker build -t myapp-image .

# Step 4: Run application container
sudo docker run --name mycontainer myapp-image
```
