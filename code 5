```bash
# Step 1: Update Ubuntu packages
sudo apt update

# Step 2: Install Java for Jenkins
sudo apt install openjdk-17-jdk -y

# Step 3: Check Java version
java --version

# Step 4: Install Jenkins repository key
curl -fsSL https://pkg.jenkins.io/debian-stable/jenkins.io-2023.key | sudo tee \
/usr/share/keyrings/jenkins-keyring.asc > /dev/null

# Step 5: Add Jenkins repository
echo deb [signed-by=/usr/share/keyrings/jenkins-keyring.asc] \
https://pkg.jenkins.io/debian-stable binary/ | sudo tee \
/etc/apt/sources.list.d/jenkins.list > /dev/null

# Step 6: Update packages again
sudo apt update

# Step 7: Install Jenkins
sudo apt install jenkins -y

# Step 8: Start Jenkins service
sudo systemctl start jenkins

# Step 9: Enable Jenkins at boot
sudo systemctl enable jenkins

# Step 10: Check Jenkins status
sudo systemctl status jenkins

# Step 11: Install Docker
sudo apt install docker.io -y

# Step 12: Start Docker service
sudo systemctl start docker

# Step 13: Enable Docker service
sudo systemctl enable docker

# Step 14: Add Jenkins user to Docker group
sudo usermod -aG docker jenkins

# Step 15: Restart Jenkins service
sudo systemctl restart jenkins

# Step 16: Open Jenkins in browser
http://localhost:8080

# Step 17: Get Jenkins admin password
sudo cat /var/lib/jenkins/secrets/initialAdminPassword
```

